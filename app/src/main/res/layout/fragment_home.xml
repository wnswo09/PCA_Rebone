<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 상단 헤더: 제목, 알림, 프로필 -->
            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="재활 홈"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivNotification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
                app:layout_constraintEnd_toStartOf="@id/ivProfileImage"
                app:layout_constraintTop_toTopOf="@id/tvHeaderTitle"
                android:layout_marginEnd="16dp"
                app:tint="#4B5563" />

            <ImageView
                android:id="@+id/ivProfileImage"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/sym_def_app_icon"
                app:layout_constraintBottom_toBottomOf="@id/tvHeaderTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvHeaderTitle" />

            <!-- 인사말 섹션 -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="안녕하세요, 김재활님"
                android:textColor="#111827"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

            <TextView
                android:id="@+id/tvSubGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="꾸준한 노력이 회복의 열쇠입니다.\n오늘도 함께 한 걸음 나아가 볼까요?"
                android:textColor="#6B7280"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

            <!-- 1. 재활 시작하기 카드 (Blue) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardStartRehab"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_start_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/tvSubGreeting">

                <TextView
                    android:id="@+id/tvStartLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="지금 바로 시작"
                    android:textColor="#BFDBFE"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="재활 시작하기"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvStartLabel" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_play"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#FFFFFF"
                    android:background="@drawable/bg_circle_white_alpha"
                    android:padding="12dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 2. 오늘의 재활 현황 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardStartRehab">

                <TextView
                    android:id="@+id/tvStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘의 재활 현황"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="65% 완료"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <FrameLayout
                    android:id="@+id/layoutProgress"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_ring"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvStatusTitle">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="32/50"
                            android:textColor="#111827"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="분 (시간)"
                            android:textColor="#6B7280"
                            android:textSize="12sp" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/layoutProgress">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_light_chip"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="소모 칼로리"
                            android:textColor="#6B7280"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="124 kcal"
                            android:textColor="#111827"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="12dp" android:layout_height="0dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_light_chip"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수행 과제"
                            android:textColor="#6B7280"
                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3/5 세트"
                            android:textColor="#111827"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 3. 대칭 점수 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardSymmetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardStatus">

                <ImageView
                    android:id="@+id/ivSymIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_mint_chip"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_sort_alphabetically"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#0D9488" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="최근 대칭 점수"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivSymIcon"
                    app:layout_constraintStart_toEndOf="@id/ivSymIcon"
                    app:layout_constraintTop_toTopOf="@id/ivSymIcon" />

                <LinearLayout
                    android:id="@+id/layoutSymScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivSymIcon">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="88"
                        android:textColor="#111827"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="6dp"
                        android:text="/100"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_mint_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="↗ 2.4%"
                    android:textColor="#0D9488"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/layoutSymScore"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/layoutSymScore" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:progress="88"
                    android:progressTint="#0D9488"
                    app:layout_constraintTop_toBottomOf="@id/layoutSymScore" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 4. 유사도 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardSimilarity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardSymmetry">

                <ImageView
                    android:id="@+id/ivSimIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_light_chip"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#1E40AF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="정상성 유사도"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivSimIcon"
                    app:layout_constraintStart_toEndOf="@id/ivSimIcon"
                    app:layout_constraintTop_toTopOf="@id/ivSimIcon" />

                <TextView
                    android:id="@+id/tvSimPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="72 %"
                    android:textColor="#111827"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivSimIcon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="표준 보행 패턴과 비교한 회복률입니다."
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSimPercent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 5. 추천 운동 섹션 -->
            <TextView
                android:id="@+id/tvRecommendTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="추천 운동"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSimilarity" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전체 보기"
                android:textColor="#1E40AF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvRecommendTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvRecommendTitle" />

            <HorizontalScrollView
                android:id="@+id/hsvExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tvRecommendTitle">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- 운동 카드 1 -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="120dp"
                                android:background="#64748B">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="12dp"
                                    android:background="@drawable/bg_level_chip"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="4dp"
                                    android:text="LEVEL 2"
                                    android:textColor="#FFFFFF"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </FrameLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp"
                                android:orientation="vertical"
                                android:background="#FFFFFF">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="고관절 가동성 강화"
                                    android:textColor="#111827"
                                    android:textStyle="bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="15분 · 중강도"
                                    android:textColor="#6B7280"
                                    android:textSize="12sp" />
                                <Button
                                    style="?android:attr/borderlessButtonStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:layout_marginTop="12dp"
                                    android:background="@drawable/bg_btn_light_blue"
                                    android:text="시작하기"
                                    android:textColor="#1E40AF"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <!-- 운동 카드 2 생략 가능 (유사 구조) -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- 6. 피드백 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_feedback_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/hsvExercises">

                <ImageView
                    android:id="@+id/ivFeedbackIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#0D9488" />

                <TextView
                    android:id="@+id/tvFeedbackTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="오늘의 한 줄 피드백"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivFeedbackIcon"
                    app:layout_constraintStart_toEndOf="@id/ivFeedbackIcon"
                    app:layout_constraintTop_toTopOf="@id/ivFeedbackIcon" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"
                    android:text="&quot;보행 시 왼쪽 발목의 각도가 어제보다 2도 더 개선되었습니다. 지금처럼 천천히, 일정하게 유지하는 것이 중요합니다.&quot;"
                    android:textColor="#4B5563"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvFeedbackTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>