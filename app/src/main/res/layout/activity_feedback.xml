<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <!-- 1. 상단 툴바 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#2563EB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 개인화 피드백"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_profile_circle"
            android:src="@android:drawable/sym_def_app_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSumLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘의 종합 요약"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            tools:layout_editor_absoluteX="76dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 스크롤 가능한 영역 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- 2. 오늘의 종합 요약 카드 (Blue) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_start_card"
                android:backgroundTint="#0F69C0"
                android:padding="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivSumIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_home"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvSummaryMain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="6dp"
                    android:text="오늘은 균형 제어 능력이 어제보다 12% 더 안정적이었어요. 꾸준한 노력이 결실을 맺고 있습니다."
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tvSumLabel" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawablePadding="6dp"
                    android:text="마지막 재활 세션: 오후 2:30"
                    android:textColor="#B0D3FF"
                    android:textSize="12sp"
                    app:drawableTint="#B0D3FF"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSummaryMain" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 3. 잘한 점 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardGoodPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardSummary">

                <ImageView
                    android:id="@+id/ivGoodIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_mint_chip"
                    android:padding="6dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#0D9488" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="잘한 점"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivGoodIcon"
                    app:layout_constraintStart_toEndOf="@id/ivGoodIcon"
                    app:layout_constraintTop_toTopOf="@id/ivGoodIcon" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/ivGoodIcon">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@android:drawable/presence_online"
                        android:drawablePadding="12dp"
                        android:text="왼쪽 발목의 가동 범위가 이전 세션 대비 5도 향상되어 보행 안정성이 크게 개선되었습니다."
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:drawableTint="#0D9488" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:drawableStart="@android:drawable/presence_online"
                        android:drawablePadding="12dp"
                        android:text="정해진 운동 횟수를 100% 달성하며 높은 집중력을 보여주셨습니다."
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:drawableTint="#0D9488" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 4. 보완할 점 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardBadPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_card"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardGoodPoints">

                <ImageView
                    android:id="@+id/ivBadIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_feedback_card"
                    android:backgroundTint="#FFEBEE"
                    android:padding="6dp"
                    android:src="@android:drawable/stat_sys_warning"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#EF4444" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="보완할 점"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivBadIcon"
                    app:layout_constraintStart_toEndOf="@id/ivBadIcon"
                    app:layout_constraintTop_toTopOf="@id/ivBadIcon" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/ivBadIcon">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@android:drawable/presence_busy"
                        android:drawablePadding="12dp"
                        android:text="운동 후반부에서 오른쪽 골반이 다소 쳐지는 경향이 발견되었습니다."
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:drawableTint="#EF4444" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:drawableStart="@android:drawable/presence_busy"
                        android:drawablePadding="12dp"
                        android:text="호흡의 리듬이 운동 템포보다 다소 빨라, 심박수 조절에 주의가 필요합니다."
                        android:textColor="#4B5563"
                        android:textSize="14sp"
                        app:drawableTint="#EF4444" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 5. 다음 시도 시 집중할 사항 카드 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardNextFocus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_feedback_card"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardBadPoints">

                <androidx.cardview.widget.CardView
                    android:id="@+id/imageNextStep"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="#E2E8F0" />
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/ivNextFocusIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_light_chip"
                    android:padding="6dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/imageNextStep"
                    app:tint="#2563EB" />

                <TextView
                    android:id="@+id/tvNextFocusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="다음 시도 시 집중할 사항"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivNextFocusIcon"
                    app:layout_constraintStart_toEndOf="@id/ivNextFocusIcon"
                    app:layout_constraintTop_toTopOf="@id/ivNextFocusIcon" />

                <TextView
                    android:id="@+id/tvNextFocusDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:lineSpacingExtra="4dp"
                    android:text="다음 세션에서는 '골반 정렬 유지'를 최우선 목표로 잡아보세요. 거울을 보며 골반의 수평을 맞춘 상태로 10초간 버티는 연습이 효과적일 거예요."
                    android:textColor="#4B5563"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/tvNextFocusLabel" />

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvNextFocusDesc">
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#골반안정" android:textColor="#2563EB" app:chipBackgroundColor="#FFFFFF" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#호흡조절" android:textColor="#2563EB" app:chipBackgroundColor="#FFFFFF" />
                    <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#천천히정확하게" android:textColor="#2563EB" app:chipBackgroundColor="#FFFFFF" />
                </com.google.android.material.chip.ChipGroup>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 6. 재활 여정의 성과 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_record_top_card"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/cardNextFocus">
                <TextView
                    android:id="@+id/tvAchieveTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="재활 여정의 성과"
                    android:textColor="#0D9488"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/tvAchieveSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="포기하지 않고 달려온 시간이 벌써 이만큼이나 되었습니다."
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/tvAchieveTitle" />
                <TextView
                    android:id="@+id/tvAchieveNum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="14"
                    android:textColor="#0D9488"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAchieveSub" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="60dp"
                    android:text="일 연속 기록 중"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvAchieveNum"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginBottom="10dp" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 7. 하단 네비게이션 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#0F69C0"
        app:itemTextColor="#0F69C0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>