<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:context=".MainActivity">

    <!-- 로고 -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:src="@drawable/logo_rebone"
        android:adjustViewBounds="true"
        android:contentDescription="@string/logo_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.42"
        android:layout_marginTop="110dp" />

    <!-- 배지 -->
    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="척수 손상 전문 AI 재활"
        android:textColor="#1F2A44"
        android:textStyle="bold"
        android:textSize="18sp"
        android:background="@drawable/bg_badge"
        android:paddingHorizontal="26dp"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="120dp"/>

    <!-- 메인 타이틀 1 -->
    <TextView
        android:id="@+id/tvTitleTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="당신의 일상을 위한"
        android:textColor="#12161D"
        android:textStyle="bold"
        android:textSize="40sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvBadge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="34dp"
        android:layout_marginHorizontal="28dp"/>

    <!-- 메인 타이틀 2 -->
    <TextView
        android:id="@+id/tvTitleBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="새로운 움직임의 시작"
        android:textColor="#0F69C0"
        android:textStyle="bold"
        android:textSize="40sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitleTop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="28dp"/>

    <!-- 설명 -->
    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="최첨단 AI 동작 분석 기술로 척수 손상 환우분들의 건강한 회복 여정을 정밀하고 따뜻하게 지원합니다."
        android:textColor="#3F4754"
        android:textSize="20sp"
        android:lineSpacingExtra="10dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitleBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="52dp"
        android:layout_marginHorizontal="40dp"/>

    <!-- 시작 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:text="시작하기  →"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="28sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#0F69C0"
        app:cornerRadius="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDesc"
        android:layout_marginTop="78dp"
        android:layout_marginHorizontal="24dp"
        android:elevation="8dp"/>

    <!-- 하단 카피라이트 -->
    <TextView
        android:id="@+id/tvCopy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2026 RehabAI Medical Solutions."
        android:textColor="#9CA3AF"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="28dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>